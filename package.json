{
  "name": "@marwantech/react-native-bottom-sheet",
  "version": "0.1.0",
  "description": "Gesture-driven bottom sheet component for React Native with snap points",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-gesture-handler": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "@jest/types": "^29.6.0",
    "ts-jest": "^29.1.0",
    "react-test-renderer": "^18.2.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.0",
    "@types/jest": "^29.5.0",
    "react-native": "^0.73.0",
    "react": "^18.2.0"
  },
  "keywords": ["react-native", "bottom-sheet", "gesture", "modal", "reanimated"],
